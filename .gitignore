# Build artefacts — never committed; produced by run-update.sh and
# build-scanner-image.sh at runtime on the build station.
/var/lib/troskel/

# Temporary working directories created by build and scan scripts.
/tmp/troskel-*/
/tmp/fc-*/
/tmp/loki-*/

# Scan logs written to the scanning host — not part of the source tree.
/var/log/troskel/

# Ignition JSON — compiled output of config/scanner-host.bu.
# Never commit the compiled form; always regenerate from source.
ignition.json

# Don't commit pass word-list
config/eff-large-wordlist.txt

# Editor and OS noise
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# Python (used in ad-hoc scripts and tooling, not in production)
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# Secrets — belt-and-braces guards. None of these should ever exist
# in the repo, but if they do, git will refuse to track them.
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519