#!/bin/bash
echo ""
echo "=== Scanner status ==="
SIG="$(cat /var/lib/troskel/signature-date 2>/dev/null || echo 'not loaded')"
YARA="$(cat /var/lib/troskel/yara-rules-date 2>/dev/null || echo 'not loaded')"
echo "  Signature date : $SIG"
echo "  YARA rules date: $YARA"
if [ -f /var/lib/troskel/scanner-rootfs.ext4 ]; then
    SZ="$(du -sh /var/lib/troskel/scanner-rootfs.ext4 | cut -f1)"
    echo "  Scanner image  : loaded ($SZ)"
else
    echo "  Scanner image  : NOT LOADED"
fi
if [ -r /dev/kvm ] && [ -w /dev/kvm ]; then
    echo "  KVM            : available"
else
    echo "  KVM            : NOT AVAILABLE — scanning will fail"
fi
LAST="$(ls -t /var/log/troskel/ 2>/dev/null | head -1)"
if [ -n "$LAST" ]; then
    RESULT="$(grep 'VERDICT' /var/log/troskel/"$LAST" 2>/dev/null | tail -1 || echo 'unknown')"
    echo "  Last scan      : $LAST"
    echo "  Last result    : $RESULT"
else
    echo "  Last scan      : none this session"
fi

# Build identity from the per-build manifest.
#
# CONTRACT (consumer side): the manifest is written to the data USB by
# scripts/prepare-data-usb.sh and copied to /var/lib/troskel by
# load-scanner. It is generated by scripts/generate-build-records.sh as
# the final step of run-update.sh. Absence is not an error: it means the
# build station has not yet run an update that generates one. On absence
# this block prints "unknown" for every identity field, which is exactly
# what prepare-data-usb.sh tells the operator to expect. If that promise
# and this behaviour drift apart, fix both. Parsing without jq (not
# installed on the scanning host), fields are stable, grep+sed suffices.
MANIFEST="/var/lib/troskel/build-manifest.json"
echo ""
echo "=== Scanner build ==="
if [ -f "$MANIFEST" ]; then
    extract() {
        # extract <key>  reads "<key>": "<value>" from $MANIFEST.
        grep -o "\"$1\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" "$MANIFEST" 2>/dev/null \
            | head -1 \
            | sed 's/.*"\([^"]*\)"$/\1/'
    }
    GEN="$(extract generated_at)"
    COMMIT="$(extract troskel_commit)"
    DIRTY="$(extract troskel_dirty)"
    echo "  Generated      : ${GEN:-unknown}"
    echo "  Troskel commit : ${COMMIT:-unknown}"
    if [ "$DIRTY" = "false" ]; then
        echo "  Tree clean     : yes"
    elif [ "$DIRTY" = "true" ]; then
        echo "  Tree clean     : NO — uncommitted changes at build time"
    else
        echo "  Tree clean     : unknown"
    fi
else
    # No manifest on the data USB. Per the contract above, report unknown
    # identity rather than implying the USB is old — post-propagation the
    # cause is a build station that has not generated one yet.
    echo "  Generated      : unknown"
    echo "  Troskel commit : unknown"
    echo "  Tree clean     : unknown"
    echo "  (no build manifest on this data USB — the build station has not"
    echo "   yet run an update that generates one)"
fi
echo ""