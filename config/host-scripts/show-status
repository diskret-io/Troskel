#!/bin/bash
echo ""
echo "=== Scanner status ==="
SIG="$(cat /var/lib/troskel/signature-date 2>/dev/null || echo 'not loaded')"
YARA="$(cat /var/lib/troskel/yara-rules-date 2>/dev/null || echo 'not loaded')"
echo "  Signature date : $SIG"
echo "  YARA rules date: $YARA"
if [ -f /var/lib/troskel/scanner-rootfs.ext4 ]; then
    SZ="$(du -sh /var/lib/troskel/scanner-rootfs.ext4 | cut -f1)"
    echo "  Scanner image  : loaded ($SZ)"
else
    echo "  Scanner image  : NOT LOADED"
fi
if [ -r /dev/kvm ] && [ -w /dev/kvm ]; then
    echo "  KVM            : available"
else
    echo "  KVM            : NOT AVAILABLE — scanning will fail"
fi
LAST="$(ls -t /var/log/troskel/ 2>/dev/null | head -1)"
if [ -n "$LAST" ]; then
    RESULT="$(grep 'VERDICT' /var/log/troskel/"$LAST" 2>/dev/null | tail -1 || echo 'unknown')"
    echo "  Last scan      : $LAST"
    echo "  Last result    : $RESULT"
else
    echo "  Last scan      : none this session"
fi

# Build identity from the per-build manifest.
#
# CONTRACT (consumer side): the manifest is generated by
# scripts/generate-build-records.sh, written to the data USB by
# scripts/prepare-data-usb.sh (which verifies it against the USB at write
# time), and copied to /var/lib/troskel by config/host-scripts/load-scanner.
# This block is the final consumer. The parser below is VENDORED verbatim from
# scripts/lib/manifest-parse.sh (the canonical definition); the host has no
# scripts/lib, so it is embedded rather than sourced. The region between the
# BEGIN/END sentinels must stay byte-identical to the lib and to load-scanner's
# copy; tests/test-manifest-propagation.sh enforces that. Do not hand-edit it
# here: change the lib, then re-vendor.
#
# Three states, distinguished deliberately:
#   - absent: an old data USB written before manifests existed. Report
#     "unknown" and say so plainly. Not an error.
#   - present and parseable (parser returns "ok"): report the fields.
#   - present but not parseable (parser returns "corrupt"): a corrupt or
#     drifted manifest. Report "unreadable" rather than "unknown", so the
#     operator can tell a corrupt manifest from a genuinely old USB.
#     load-scanner already warns at load time; this is the matching display
#     state.
#
# MANIFEST defaults to the loaded location; overridable only so the regression
# test can point the parser at fixtures without a real /var/lib/troskel.
# >>> BEGIN manifest-parse vendored region (keep byte-identical across copies) >>>
_manifest_extract_str() {  # _manifest_extract_str <key> <path> -> quoted-string value or empty
    grep -o "\"$1\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" "$2" 2>/dev/null \
        | head -1 \
        | sed 's/.*"\([^"]*\)"$/\1/'
}

_manifest_extract_dirty() {  # _manifest_extract_dirty <path> -> true|false or empty
    grep -o "\"troskel_dirty\"[[:space:]]*:[[:space:]]*\(true\|false\)" "$1" 2>/dev/null \
        | head -1 \
        | grep -o '\(true\|false\)$'
}

manifest_parse() {  # manifest_parse <path> ; sets MANIFEST_* globals, prints ok|corrupt
    local path="$1"
    MANIFEST_GENERATED="$(_manifest_extract_str generated_at "$path")"
    MANIFEST_COMMIT="$(_manifest_extract_str troskel_commit "$path")"
    MANIFEST_DIRTY="$(_manifest_extract_dirty "$path")"
    if [ -n "$MANIFEST_GENERATED" ] && [ -n "$MANIFEST_COMMIT" ] && [ -n "$MANIFEST_DIRTY" ]; then
        printf 'ok\n'
        return 0
    fi
    printf 'corrupt\n'
    return 1
}
# <<< END manifest-parse vendored region <<<

MANIFEST="${MANIFEST:-/var/lib/troskel/build-manifest.json}"
echo ""
echo "=== Scanner build ==="
if [ -f "$MANIFEST" ]; then
    if manifest_parse "$MANIFEST" >/dev/null; then
        echo "  Generated      : ${MANIFEST_GENERATED}"
        echo "  Troskel commit : ${MANIFEST_COMMIT}"
        if [ "$MANIFEST_DIRTY" = "false" ]; then
            echo "  Tree clean     : yes"
        else
            echo "  Tree clean     : NO, uncommitted changes at build time"
        fi
    else
        # File exists but the required fields do not all extract: corrupt or
        # structurally drifted. Distinct from the absent case below.
        echo "  Generated      : unreadable"
        echo "  Troskel commit : unreadable"
        echo "  Tree clean     : unreadable"
        echo "  (build manifest present but could not be parsed, it may be"
        echo "   corrupt or from an incompatible build; load-scanner warned at"
        echo "   load time)"
    fi
else
    # No manifest on the data USB. Per the contract above, this means an old
    # USB predating manifest support: write-time generation is now mandatory,
    # so a freshly written USB always carries one.
    echo "  Generated      : unknown"
    echo "  Troskel commit : unknown"
    echo "  Tree clean     : unknown"
    echo "  (no build manifest on this data USB, it predates manifest support;"
    echo "   rewrite it on the build station to populate build identity)"
fi
echo ""