#!/bin/bash
set -euo pipefail

# Load operational tunables from the data USB (placed here by load-scanner).
# shellcheck source=/dev/null
[ -f /var/lib/troskel/scanner.env ] && source /var/lib/troskel/scanner.env
CLAM_SIG_MAX_AGE_DAYS="${CLAM_SIG_MAX_AGE_DAYS:-30}"

PASS=0
FAIL=0

check() {
    local DESC="$1"
    local RESULT="$2"
    if [ "$RESULT" = "ok" ]; then
        printf "  [PASS] %s\n" "$DESC"
        PASS=$((PASS+1))
    else
        printf "  [FAIL] %s — %s\n" "$DESC" "$RESULT"
        FAIL=$((FAIL+1))
    fi
}

echo ""
echo "=== System readiness check ==="
echo ""

# Required external tools. The host scripts (load-scanner, scan-wrap,
# show-status, this script) depend on these being present in the CoreOS image.
# sha256sum in particular underwrites load-scanner's host-side rootfs
# verification: without it that verification cannot run. openssl and jq
# underwrite the data-USB manifest authenticity gate (the signature check in
# load-scanner): openssl verifies the detached ed25519 signature, jq parses
# the signed manifest. Without either, that gate cannot run, and its absence
# would surface as an opaque "command not found" mid-load rather than here.
# jq is present in the Fedora CoreOS base image and is pinned transitively by
# the pinned image version (it is not separately downloaded or layered); the
# version-floor check below is the loud guard that catches an image whose jq
# has regressed below what the manifest logic needs. Checking the toolset here
# turns a silent assumption about the base image into a loud, diagnosable
# readiness failure. If a future image drop ever removed coreutils, openssl,
# or jq, this is where it surfaces.
MISSING_TOOLS=""
for TOOL in sha256sum openssl jq grep sed awk date head cp mkdir mount umount; do
    command -v "$TOOL" >/dev/null 2>&1 || MISSING_TOOLS="${MISSING_TOOLS} ${TOOL}"
done
check "Required tools present (sha256sum, openssl, jq, coreutils, mount)" \
    "$([ -z "$MISSING_TOOLS" ] && echo ok || echo "missing:${MISSING_TOOLS}")"

# jq version floor. The manifest logic (scripts/lib/medium-manifest.sh, vendored
# into load-scanner) relies on jq behaviour stable from 1.7 onward (-n,
# --argjson, -c, // empty, has()). The pinned CoreOS image currently ships a
# much newer jq; this check does not pin the version (option C: the image pin is
# the real pin) but fails loudly if a future image regresses jq below the floor,
# which would otherwise surface as a subtle manifest misparse on the security
# path. Parse major.minor numerically: jq reports "jq-1.6", "jq-1.7.1",
# "jq-1.8.1", or a Fedora "jq-1.8.1-3.fc44" form, so a string match on a single
# version would wrongly reject newer jq. An unparseable version is a failure,
# not a pass.
JQ_FLOOR_MAJOR=1
JQ_FLOOR_MINOR=7
if command -v jq >/dev/null 2>&1; then
    JQ_RAW="$(jq --version 2>/dev/null || echo "")"
    JQ_NUM="${JQ_RAW#jq-}"; JQ_NUM="${JQ_NUM#jq }"
    JQ_MAJOR="${JQ_NUM%%.*}"
    JQ_MINOR_REST="${JQ_NUM#*.}"; JQ_MINOR="${JQ_MINOR_REST%%.*}"
    case "${JQ_MAJOR}${JQ_MINOR}" in
        ""|*[!0-9]*)
            check "jq version >= ${JQ_FLOOR_MAJOR}.${JQ_FLOOR_MINOR}" \
                "unparseable version: ${JQ_RAW:-none}" ;;
        *)
            if [ "$JQ_MAJOR" -gt "$JQ_FLOOR_MAJOR" ] \
               || { [ "$JQ_MAJOR" -eq "$JQ_FLOOR_MAJOR" ] && [ "$JQ_MINOR" -ge "$JQ_FLOOR_MINOR" ]; }; then
                check "jq version >= ${JQ_FLOOR_MAJOR}.${JQ_FLOOR_MINOR} (found ${JQ_MAJOR}.${JQ_MINOR})" "ok"
            else
                check "jq version >= ${JQ_FLOOR_MAJOR}.${JQ_FLOOR_MINOR}" \
                    "found ${JQ_MAJOR}.${JQ_MINOR}, below floor"
            fi ;;
    esac
else
    check "jq version >= ${JQ_FLOOR_MAJOR}.${JQ_FLOOR_MINOR}" "jq not present"
fi

NET=$(ip link show | grep -v "lo:" | grep -c "UP" || true)
check "No active network interfaces beyond loopback" \
    "$([ "$NET" -eq 0 ] && echo ok || echo "${NET} interface(s) active")"

check "KVM accessible" \
    "$([ -r /dev/kvm ] && [ -w /dev/kvm ] && echo ok || echo "not accessible")"

check "Scanner image loaded" \
    "$([ -f /var/lib/troskel/scanner-rootfs.ext4 ] && echo ok || echo "not found")"

check "Guest kernel loaded" \
    "$([ -f /var/lib/troskel/vmlinux ] && echo ok || echo "not found")"

ZINC=$(systemctl is-enabled zincati 2>/dev/null || echo "unknown")
check "Auto-update (zincati) is disabled" \
    "$([ "$ZINC" = "masked" ] && echo ok || echo "status: $ZINC")"

NET_IN_SCAN=$(grep -c "network-interfaces" /usr/local/bin/scan-wrap 2>/dev/null || true)
check "No network interface in scan config" \
    "$([ "$NET_IN_SCAN" -eq 0 ] && echo ok || echo "network config found — review scan-wrap")"

if [ -f /var/lib/troskel/signature-date ]; then
    SIG_DATE="$(cat /var/lib/troskel/signature-date)"
    SIG_EPOCH="$(date -d "$SIG_DATE" +%s 2>/dev/null || echo 0)"
    NOW_EPOCH="$(date +%s)"
    AGE_DAYS=$(( (NOW_EPOCH - SIG_EPOCH) / 86400 ))
    check "Signature date present and fresh (age: ${AGE_DAYS} days)" \
        "$([ "$AGE_DAYS" -le "$CLAM_SIG_MAX_AGE_DAYS" ] && echo ok || echo "signatures are ${AGE_DAYS} days old — run update")"
else
    check "Signature date present" "not found"
fi

echo ""
echo "=== Results: ${PASS} passed, ${FAIL} failed ==="
echo ""

if [ "$FAIL" -gt 0 ]; then
    echo "[!] One or more checks failed. Do not scan until resolved."
    echo "    Contact the admin if you are unsure how to proceed."
    exit 1
else
    echo "[+] All checks passed. System is ready to scan."
    exit 0
fi
